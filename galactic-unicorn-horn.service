[Unit]
Description=Galactic Unicorn Horn - Calendar LED Display
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/galactic-unicorn-horn
ExecStart=/usr/bin/python3 /home/pi/galactic-unicorn-horn/main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
