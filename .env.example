# Galactic Unicorn Leg device IPs (comma-separated for multiple devices)
DEVICE_IPS=192.168.1.100,192.168.1.101
# Or use single device (backward compatible)
# DEVICE_IP=192.168.1.100

# --- Google Calendar (iCal URL) ---
# Settings → Target calendar → "Secret address in iCal format"
# Multiple calendars: comma-separated
ICAL_URLS=https://calendar.google.com/calendar/ical/xxxxx/basic.ics

# --- Apple Calendar (CalDAV auth) ---
# Generate app-specific password at appleid.apple.com
ICLOUD_USERNAME=your@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Calendar fetch interval (seconds)
FETCH_INTERVAL=300

# Display settings
SCROLL_SPEED=medium
# Font path (empty = fonts/PixelMplus10-Regular.ttf)
FONT_PATH=
FONT_SIZE=10

# --- LLM (Ollama / LLMHAT) ---
# Ollama API URL (auto-detected if empty)
OLLAMA_URL=
# Preferred model name (auto-selected if empty)
OLLAMA_MODEL=
