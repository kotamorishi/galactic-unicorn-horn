# Galactic Unicorn Leg デバイスのIPアドレス
DEVICE_IP=192.168.1.100

# iCal URL（複数カレンダーはカンマ区切り）
# Google カレンダー: 設定 → 対象カレンダー → 「iCal形式の秘密のアドレス」
# Apple iCal: カレンダー共有 → 公開カレンダーのURL
ICAL_URLS=https://calendar.google.com/calendar/ical/xxxxx/basic.ics,https://p123-caldav.icloud.com/published/xxxxx

# カレンダー取得間隔（秒）
FETCH_INTERVAL=300

# 表示設定
SCROLL_SPEED=medium
# フォントのパス（空欄の場合はfonts/PixelMplus12-Regular.ttf）
# FONT_PATH=fonts/PixelMplus12-Bold.ttf
FONT_PATH=
FONT_SIZE=12
